# Alpaca paper trading credentials. Never commit real credentials.
ALPACA_API_KEY=your_paper_key_here
ALPACA_SECRET_KEY=your_paper_secret_here

# Platform services.
DATABASE_URL=postgresql+psycopg://trader:trader@postgres:5432/trading_bot
REDIS_URL=redis://redis:6379/0

# Market data providers.
FINNHUB_API_KEY=your_finnhub_key_here
POLYGON_API_KEY=your_polygon_key_here
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here
TWELVE_DATA_API_KEY=your_twelve_data_key_here
FMP_API_KEY=your_financial_modeling_prep_key_here

# Version 1 is paper-first. Leave this false unless you have deliberately
# implemented and reviewed live trading support in a later version.
ALLOW_LIVE_TRADING=false

# Set to true to disable new buys immediately.
EMERGENCY_STOP=false

# Daily report email. For Gmail, use an app password, not your normal password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=gkkcsp2023@gmail.com
SMTP_PASSWORD=Honey@143
SMTP_FROM_EMAIL=gkkcsp2023@gmail.com
SMTP_USE_TLS=true
DAILY_REPORT_TO=gopikonakanchi96@gmail.com
